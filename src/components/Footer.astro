---
import { siteCopy } from '../data/siteCopy';
import { withBase } from '../utils/paths';
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div>
      <p class="footer-label">{siteCopy.footer.socialLabel}</p>
      <div class="social-links" aria-label="Social media links">
        <a href="https://www.instagram.com/masta_dan_/" target="_blank" rel="noopener noreferrer" aria-label="Masta Dan Instagram">
          <img src={withBase('assets/images/social/instagram.webp')} alt="" />
        </a>
        <a href="https://www.threads.com/@masta_dan_" target="_blank" rel="noopener noreferrer" aria-label="Masta Dan Threads">
          <img src={withBase('assets/images/social/threads.webp')} alt="" />
        </a>
        <span class="social-dot-placeholder" aria-hidden="true">●</span>
      </div>
    </div>
    <div>
      <p class="footer-label">{siteCopy.footer.contactLabel}</p>
      <a href={siteCopy.contact.emailUrl} target="_blank" rel="noopener noreferrer">{siteCopy.contact.email}</a>
    </div>
    <p class="footer-message">{siteCopy.footer.message}</p>
  </div>
  <div class="shell footer-bottom">© <span data-year></span> {siteCopy.footer.copyrightSuffix}</div>
</footer>
