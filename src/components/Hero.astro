---
import AssetSlot from './AssetSlot.astro';
import { siteCopy } from '../data/siteCopy';
---

<section class="hero shell has-hero-image" aria-labelledby="hero-title">
  <h1 id="hero-title" class="sr-only">{siteCopy.hero.titleFirst} {siteCopy.hero.titleSecond}</h1>
  <AssetSlot
    src={siteCopy.hero.image}
    alt={siteCopy.hero.imageAlt}
    label="Homepage hero / banner image"
    hint="Place at public/assets/images/hero/home-hero.png"
    class="hero-art reveal"
    loading="eager"
    fetchpriority="high"
  />
  <a class="scroll-cue" href="#about-preview" aria-label="Scroll to About us"><span>↓</span></a>
</section>
