---
import AssetSlot from './AssetSlot.astro';
import { siteCopy } from '../data/siteCopy';
import { withBase } from '../utils/paths';

const layerBase = 'assets/images/hero/layers';
const heroCharacters = [
  {
    id: 'geri',
    label: 'Geri',
    src: `${layerBase}/geri.png`,
    style: '--hero-x: -1.8%; --hero-y: 31%; --hero-w: 19.1%; --hero-delay: -0.4s; --hero-duration: 3.7s; --hero-range: 5px; --hero-rotate: -1.5deg; --hero-radius: 160;',
  },
  {
    id: 'yy',
    label: 'YY',
    src: `${layerBase}/yy.png`,
    style: '--hero-x: 19.2%; --hero-y: 2.2%; --hero-w: 21.1%; --hero-delay: -1.1s; --hero-duration: 3.9s; --hero-range: 6px; --hero-rotate: 1.5deg; --hero-radius: 175;',
  },
  {
    id: 'ethan-yes',
    label: 'Ethan-Yes',
    src: `${layerBase}/ethan-yes.png`,
    style: '--hero-x: 32.1%; --hero-y: 50.2%; --hero-w: 16.2%; --hero-delay: -1.7s; --hero-duration: 4.1s; --hero-range: 4px; --hero-rotate: -2deg; --hero-radius: 145;',
  },
  {
    id: 'popo',
    label: 'Popo',
    src: `${layerBase}/popo.png`,
    style: '--hero-x: 47%; --hero-y: 22%; --hero-w: 14%; --hero-delay: -1.9s; --hero-duration: 3.5s; --hero-range: 4px; --hero-rotate: -2deg; --hero-radius: 135;',
  },
  {
    id: 'ahua',
    label: 'Ahua',
    src: `${layerBase}/ahua.png`,
    style: '--hero-x: 59%; --hero-y: 33.4%; --hero-w: 19.9%; --hero-delay: -0.8s; --hero-duration: 3.6s; --hero-range: 5px; --hero-rotate: 1deg; --hero-radius: 175;',
  },
  {
    id: 'p-chan',
    label: 'P-Chan',
    src: `${layerBase}/p-chan.png`,
    style: '--hero-x: 79.5%; --hero-y: 55%; --hero-w: 12.3%; --hero-delay: -0.2s; --hero-duration: 4.2s; --hero-range: 4px; --hero-rotate: 2deg; --hero-radius: 130;',
  },
  {
    id: 'chowee',
    label: 'Chowee',
    src: `${layerBase}/chowee.png`,
    style: '--hero-x: 82.8%; --hero-y: 5.8%; --hero-w: 19.7%; --hero-delay: -1.4s; --hero-duration: 3.8s; --hero-range: 5px; --hero-rotate: -1deg; --hero-radius: 165;',
  },
];
---

<section class="hero shell hero-layered has-hero-image" aria-labelledby="hero-title">
  <h1 id="hero-title" class="sr-only">{siteCopy.hero.titleFirst} {siteCopy.hero.titleSecond}</h1>

  <div class="hero-stage reveal" data-hero-stage aria-hidden="true">
    <div class="hero-stage-placeholder">
      <span>Hero layer assets loading</span>
      <small>Place transparent PNGs in public/assets/images/hero/layers/</small>
    </div>

    <img
      class="hero-cn"
      src={withBase(`${layerBase}/hero-cn.png`)}
      alt=""
      loading="eager"
      decoding="async"
      fetchpriority="high"
      data-hero-layer
    />

    <img
      class="hero-wordmark"
      src={withBase(`${layerBase}/hero-text.png`)}
      alt=""
      loading="eager"
      decoding="async"
      fetchpriority="high"
      data-hero-layer
    />

    {heroCharacters.map((character) => (
      <div
        class:list={['hero-character', `hero-character--${character.id}`]}
        style={character.style}
        data-repel
      >
        <img
          src={withBase(character.src)}
          alt=""
          loading="eager"
          decoding="async"
          fetchpriority="high"
          data-hero-layer
        />
        <span class="hero-character-placeholder">{character.label}</span>
      </div>
    ))}

    <img
      class="hero-decor hero-decor-highlight"
      src={withBase('assets/images/home/homepage-highlight-asset.png')}
      alt=""
      loading="eager"
      decoding="async"
      data-hero-layer
    />

    <img
      class="hero-decor hero-decor-starlight"
      src={withBase('assets/images/home/homepage-starlight-asset.png')}
      alt=""
      loading="eager"
      decoding="async"
      data-hero-layer
    />
  </div>

  <AssetSlot
    src={siteCopy.hero.image}
    alt={siteCopy.hero.imageAlt}
    label="Homepage hero / banner image"
    hint="Place at public/assets/images/hero/home-hero.png"
    class="hero-art hero-fallback reveal"
    loading="eager"
    fetchpriority="high"
  />

  <a class="scroll-cue" href="#about-preview" aria-label="Scroll to About us">
    <img src={withBase('assets/images/ui/down-button.png')} alt="" aria-hidden="true" />
  </a>
</section>
