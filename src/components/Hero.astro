---
import AssetSlot from './AssetSlot.astro';
import { siteCopy } from '../data/siteCopy';
import { withBase } from '../utils/paths';

const layerBase = 'assets/images/hero/layers';
const heroCharacters = [
  {
    id: 'chowee',
    label: 'Chowee',
    src: `${layerBase}/chowee.png`,
    style: '--hero-x: 0%; --hero-y: 34%; --hero-w: 25%; --hero-delay: -0.4s; --hero-duration: 3.7s; --hero-range: 5px; --hero-rotate: -1.5deg; --hero-radius: 170;',
  },
  {
    id: 'yy',
    label: 'YY',
    src: `${layerBase}/yy.png`,
    style: '--hero-x: 21%; --hero-y: 33%; --hero-w: 23%; --hero-delay: -1.1s; --hero-duration: 3.9s; --hero-range: 6px; --hero-rotate: 1.5deg; --hero-radius: 175;',
  },
  {
    id: 'ethan-yes',
    label: 'Ethan-Yes',
    src: `${layerBase}/ethan-yes.png`,
    style: '--hero-x: 38%; --hero-y: 27%; --hero-w: 12%; --hero-delay: -1.7s; --hero-duration: 4.1s; --hero-range: 4px; --hero-rotate: -2deg; --hero-radius: 145;',
  },
  {
    id: 'ahua',
    label: 'Ahua',
    src: `${layerBase}/ahua.png`,
    style: '--hero-x: 42%; --hero-y: 33%; --hero-w: 25%; --hero-delay: -0.8s; --hero-duration: 3.6s; --hero-range: 5px; --hero-rotate: 1deg; --hero-radius: 180;',
  },
  {
    id: 'gerri',
    label: 'Gerri',
    src: `${layerBase}/gerri.png`,
    style: '--hero-x: 63%; --hero-y: 36%; --hero-w: 21%; --hero-delay: -1.4s; --hero-duration: 3.8s; --hero-range: 5px; --hero-rotate: -1deg; --hero-radius: 170;',
  },
  {
    id: 'p-chan',
    label: 'P-Chan',
    src: `${layerBase}/p-chan.png`,
    style: '--hero-x: 80%; --hero-y: 57%; --hero-w: 15%; --hero-delay: -0.2s; --hero-duration: 4.2s; --hero-range: 4px; --hero-rotate: 2deg; --hero-radius: 140;',
  },
  {
    id: 'popo',
    label: 'Popo',
    src: `${layerBase}/popo.png`,
    style: '--hero-x: 89%; --hero-y: 33%; --hero-w: 10%; --hero-delay: -1.9s; --hero-duration: 3.5s; --hero-range: 4px; --hero-rotate: -2deg; --hero-radius: 135;',
  },
];
---

<section class="hero shell hero-layered has-hero-image" aria-labelledby="hero-title">
  <h1 id="hero-title" class="sr-only">{siteCopy.hero.titleFirst} {siteCopy.hero.titleSecond}</h1>

  <div class="hero-stage reveal" data-hero-stage aria-hidden="true">
    <div class="hero-stage-placeholder">
      <span>Hero layer assets loading</span>
      <small>Place transparent PNGs in public/assets/images/hero/layers/</small>
    </div>

    <img
      class="hero-wordmark"
      src={withBase(`${layerBase}/mastadan-wordmark.png`)}
      alt=""
      loading="eager"
      decoding="async"
      fetchpriority="high"
      data-hero-layer
    />

    {heroCharacters.map((character) => (
      <div
        class:list={['hero-character', `hero-character--${character.id}`]}
        style={character.style}
        data-repel
      >
        <img
          src={withBase(character.src)}
          alt=""
          loading="eager"
          decoding="async"
          fetchpriority="high"
          data-hero-layer
        />
        <span class="hero-character-placeholder">{character.label}</span>
      </div>
    ))}
  </div>

  <AssetSlot
    src={siteCopy.hero.image}
    alt={siteCopy.hero.imageAlt}
    label="Homepage hero / banner image"
    hint="Place at public/assets/images/hero/home-hero.png"
    class="hero-art hero-fallback reveal"
    loading="eager"
    fetchpriority="high"
  />

  <a class="scroll-cue" href="#about-preview" aria-label="Scroll to About us"><span aria-hidden="true">⌄</span></a>
</section>
