---
import { creatorFilters } from '../data/shopCreators';
import { themeCollections } from '../data/shopCollections';
import { withBase } from '../utils/paths';
---

<section class="section shell shopify-buy-section" aria-label="Shopping products">
  <div class="shop-filter-panel reveal" aria-label="Shop filters">
    <div class="shop-filter-dropdown" data-shop-filter-dropdown>
      <button
        class="shop-filter-trigger"
        type="button"
        aria-expanded="false"
        aria-controls="shop-filter-menu"
        data-shop-filter-trigger
      >
        <span data-shop-filter-current>作品分類</span>
        <img src={withBase('assets/images/ui/down-button.png')} alt="" aria-hidden="true" />
      </button>

      <div class="shop-filter-menu" id="shop-filter-menu" role="listbox" hidden data-shop-filter-menu>
        <button
          class="shop-filter-option is-active"
          type="button"
          role="option"
          aria-selected="true"
          data-shop-filter-option
          data-filter-mode="theme"
        >
          作品分類
        </button>
        <button
          class="shop-filter-option"
          type="button"
          role="option"
          aria-selected="false"
          data-shop-filter-option
          data-filter-mode="creator"
        >
          創作者分類
        </button>
      </div>
    </div>

    <div class="shop-filter-buttons" role="group" aria-label="作品分類" data-shop-filter-group="theme">
      {themeCollections.map((collection) => (
        <button
          class="shop-filter-button"
          type="button"
          data-shop-collection={collection.slug}
          aria-pressed={collection.isDefault ? 'true' : 'false'}
        >
          {collection.label}
        </button>
      ))}
    </div>

    <div class="shop-filter-buttons" role="group" aria-label="創作者分類" data-shop-filter-group="creator" hidden>
      {creatorFilters.map((creator) => (
        <button
          class="shop-filter-button"
          type="button"
          data-shop-creator={creator.slug}
          aria-pressed={creator.isDefault ? 'true' : 'false'}
        >
          {creator.label}
        </button>
      ))}
    </div>
  </div>

  <div class="shopify-buy-panel reveal" style="--delay: 90ms">
    <div id="collection-component-1782576872484" class="shopify-buy-mount"></div>
    <p class="shopify-status" data-shopify-status>商品載入中…</p>
    <noscript>
      <p class="shopify-status">請啟用 JavaScript 以查看商品及結帳。</p>
    </noscript>
  </div>
</section>

<script id="shop-collections-data" type="application/json" set:html={JSON.stringify(themeCollections)}></script>
<script id="shop-creators-data" type="application/json" set:html={JSON.stringify(creatorFilters)}></script>

<script is:inline>
  (() => {
    const componentId = 'collection-component-1782576872484';
    const mountNode = document.getElementById(componentId);
    const statusNode = document.querySelector('[data-shopify-status]');
    const collectionDataNode = document.getElementById('shop-collections-data');
    const creatorDataNode = document.getElementById('shop-creators-data');
    const dropdown = document.querySelector('[data-shop-filter-dropdown]');
    const dropdownTrigger = document.querySelector('[data-shop-filter-trigger]');
    const dropdownMenu = document.querySelector('[data-shop-filter-menu]');
    const dropdownCurrent = document.querySelector('[data-shop-filter-current]');
    const filterOptions = Array.from(document.querySelectorAll('[data-shop-filter-option]'));
    const collectionButtons = Array.from(document.querySelectorAll('[data-shop-collection]'));
    const creatorButtons = Array.from(document.querySelectorAll('[data-shop-creator]'));
    const filterGroups = Array.from(document.querySelectorAll('[data-shop-filter-group]'));
    const scriptURL = 'https://sdks.shopifycdn.com/buy-button/latest/buy-button-storefront.min.js';
    const collections = collectionDataNode ? JSON.parse(collectionDataNode.textContent || '[]') : [];
    const creators = creatorDataNode ? JSON.parse(creatorDataNode.textContent || '[]') : [];
    let activeComponent = null;
    let activeKey = '';
    let shopifyUi = null;

    if (!mountNode || mountNode.dataset.shopifyMounted === 'true') return;
    mountNode.dataset.shopifyMounted = 'true';

    const setStatus = (message, isError = false) => {
      if (!statusNode) return;
      statusNode.textContent = message;
      statusNode.hidden = !message;
      statusNode.classList.toggle('is-error', isError);
    };

    const setDropdownOpen = (isOpen) => {
      if (!dropdownTrigger || !dropdownMenu || !dropdown) return;
      dropdown.classList.toggle('is-open', isOpen);
      dropdownTrigger.setAttribute('aria-expanded', String(isOpen));
      dropdownMenu.hidden = !isOpen;
    };

    const setActiveCollectionButton = (slug) => {
      collectionButtons.forEach((button) => {
        button.setAttribute('aria-pressed', String(button.dataset.shopCollection === slug));
      });
      creatorButtons.forEach((button) => button.setAttribute('aria-pressed', 'false'));
    };

    const setActiveCreatorButton = (slug) => {
      creatorButtons.forEach((button) => {
        button.setAttribute('aria-pressed', String(button.dataset.shopCreator === slug));
      });
      collectionButtons.forEach((button) => button.setAttribute('aria-pressed', 'false'));
    };

    const setActiveFilterOption = (mode) => {
      filterOptions.forEach((option) => {
        const isSelected = option.dataset.filterMode === mode;
        option.classList.toggle('is-active', isSelected);
        option.setAttribute('aria-selected', String(isSelected));
      });
    };

    const clearActiveComponent = () => {
      activeComponent?.destroy?.();
      activeComponent = null;
      activeKey = '';
      mountNode.replaceChildren();
    };

    const setFilterMode = (mode, label) => {
      filterGroups.forEach((group) => {
        group.hidden = group.dataset.shopFilterGroup !== mode;
      });
      if (dropdownCurrent && label) dropdownCurrent.textContent = label;
      setActiveFilterOption(mode);
      setDropdownOpen(false);

      if (mode === 'creator') {
        const defaultCreator = creators.find((creator) => creator.isDefault) || creators[0];
        renderCollection(defaultCreator, 'creator');
        return;
      }

      const defaultCollection = collections.find((collection) => collection.isDefault) || collections[0];
      renderCollection(defaultCollection, 'theme');
    };

    const buttonStyles = {
      'font-family': 'Nunito, Candara, sans-serif',
      'font-size': '14px',
      'font-weight': '900',
      height: '54px',
      'min-height': '54px',
      'padding-top': '0px',
      'padding-bottom': '0px',
      'line-height': '54px',
      'background-color': '#4e98ef',
      'border-radius': '999px',
      ':hover': { 'background-color': '#4689d7' },
      ':focus': { 'background-color': '#4689d7' },
    };

    const quantityInputStyles = {
      'font-size': '14px',
      height: '54px',
      'min-height': '54px',
      'padding-top': '0px',
      'padding-bottom': '0px',
      'line-height': '54px',
    };

    const mutedText = { color: '#747d89' };

    const extractCollectionId = (snippet) => {
      const match = snippet.match(/createComponent\(['"]collection['"][\s\S]*?id\s*:?\s*['"]?(\d+)/i);
      return match?.[1] || '';
    };

    const resolveCollectionId = async (item) => {
      if (item.collectionId) return item.collectionId;
      if (!item.snippetPath) return '';

      const response = await fetch(item.snippetPath, { cache: 'no-store' });
      if (!response.ok) return '';
      return extractCollectionId(await response.text());
    };

    const renderCollection = async (item, source = 'theme') => {
      if (!item || !shopifyUi) return;

      const nextKey = `${source}:${item.slug}`;
      if (activeKey === nextKey) return;

      activeKey = nextKey;
      source === 'creator' ? setActiveCreatorButton(item.slug) : setActiveCollectionButton(item.slug);
      activeComponent?.destroy?.();
      activeComponent = null;
      mountNode.replaceChildren();
      setStatus('商品載入中…');

      const collectionId = await resolveCollectionId(item);
      if (!collectionId) {
        setStatus('準備中...');
        return;
      }

      activeComponent = shopifyUi.createComponent('collection', {
        id: collectionId,
        node: mountNode,
        moneyFormat: '%24%7B%7Bamount%7D%7D',
        options: {
          product: {
            buttonDestination: 'modal',
            contents: { options: false },
            text: { button: '查看詳情' },
            styles: {
              product: {
                'text-align': 'center',
                '@media (min-width: 601px)': {
                  'max-width': 'calc(33.33333% - 24px)',
                  'margin-left': '24px',
                  'margin-bottom': '50px',
                  width: 'calc(33.33333% - 24px)',
                },
              },
              img: {
                width: '100%',
                height: '100%',
                position: 'absolute',
                left: '0',
                right: '0',
                top: '0',
                bottom: '0',
                'object-fit': 'contain',
              },
              imgWrapper: {
                'max-width': '100%',
                width: '100%',
                'padding-top': '100%',
                position: 'relative',
                height: '0',
                overflow: 'hidden',
              },
              title: {
                color: '#4e98ef',
                'font-family': 'Nunito, Candara, sans-serif',
                'font-size': '16px',
                'font-weight': '900',
              },
              button: buttonStyles,
              quantityInput: quantityInputStyles,
              price: {
                ...mutedText,
                'font-family': 'Nunito, Candara, sans-serif',
              },
              compareAt: mutedText,
              unitPrice: mutedText,
            },
          },
          productSet: {
            styles: {
              products: {
                '@media (min-width: 601px)': { 'margin-left': '-24px' },
              },
            },
          },
          modalProduct: {
            contents: {
              img: false,
              imgWithCarousel: true,
              button: false,
              buttonWithQuantity: true,
            },
            text: { button: '加入購物車' },
            styles: {
              product: {
                '@media (min-width: 601px)': {
                  'max-width': '100%',
                  'margin-left': '0px',
                  'margin-bottom': '0px',
                },
              },
              img: {
                'max-width': '100%',
                width: '100%',
                height: 'auto',
              },
              imgWrapper: {
                'max-width': '100%',
                width: '100%',
              },
              imgWithCarousel: {
                'max-width': '100%',
                width: '100%',
              },
              button: buttonStyles,
              quantityInput: quantityInputStyles,
              title: {
                'font-family': 'Nunito, Candara, sans-serif',
                'font-weight': '900',
                'font-size': '26px',
                color: '#4c4c4c',
              },
              price: {
                'font-family': 'Nunito, Candara, sans-serif',
                'font-size': '18px',
                color: '#747d89',
              },
            },
          },
          modal: {
            styles: {
              modal: { 'background-color': '#eaf0f8' },
            },
          },
          cart: {
            text: {
              title: '購物車',
              total: '小計',
              notice: '',
              button: '結帳',
            },
            styles: {
              button: buttonStyles,
              title: mutedText,
              header: mutedText,
              lineItems: mutedText,
              subtotalText: mutedText,
              subtotal: mutedText,
              notice: mutedText,
              currency: mutedText,
              close: { ...mutedText, ':hover': mutedText },
              empty: mutedText,
              cart: { 'background-color': '#eaf0f8' },
              footer: { 'background-color': '#eaf0f8' },
            },
          },
          toggle: {
            styles: {
              toggle: {
                'font-family': 'Nunito, Candara, sans-serif',
                'background-color': '#4e98ef',
                ':hover': { 'background-color': '#4689d7' },
                ':focus': { 'background-color': '#4689d7' },
              },
              count: { 'font-size': '14px' },
            },
          },
          lineItem: {
            styles: {
              variantTitle: mutedText,
              title: mutedText,
              price: mutedText,
              fullPrice: mutedText,
              discount: mutedText,
              discountIcon: { fill: '#747d89' },
              quantity: mutedText,
              quantityIncrement: { ...mutedText, 'border-color': '#747d89' },
              quantityDecrement: { ...mutedText, 'border-color': '#747d89' },
              quantityInput: { ...mutedText, 'border-color': '#747d89' },
            },
          },
        },
      });
      setStatus('');
    };

    const ShopifyBuyInit = () => {
      if (!window.ShopifyBuy || !window.ShopifyBuy.UI) {
        setStatus('商品未能載入，請重新整理頁面。', true);
        return;
      }

      const client = window.ShopifyBuy.buildClient({
        domain: 'q1h1fd-1k.myshopify.com',
        storefrontAccessToken: 'bf59ceedee547abd0dc0135180402dbd',
      });

      window.ShopifyBuy.UI.onReady(client)
        .then((ui) => {
          shopifyUi = ui;
          const defaultCollection = collections.find((collection) => collection.isDefault) || collections[0];
          renderCollection(defaultCollection, 'theme');
        })
        .catch(() => setStatus('商品未能載入，請重新整理頁面。', true));
    };

    const loadScript = () => {
      const script = document.createElement('script');
      script.async = true;
      script.src = scriptURL;
      script.onload = ShopifyBuyInit;
      script.onerror = () => setStatus('商品未能載入，請重新整理頁面。', true);
      (document.head || document.body).appendChild(script);
    };

    dropdownTrigger?.addEventListener('click', () => {
      setDropdownOpen(dropdownTrigger.getAttribute('aria-expanded') !== 'true');
    });

    filterOptions.forEach((option) => {
      option.addEventListener('click', () => setFilterMode(option.dataset.filterMode, option.textContent.trim()));
    });

    document.addEventListener('click', (event) => {
      if (!dropdown?.contains(event.target)) setDropdownOpen(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setDropdownOpen(false);
    });

    collectionButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextCollection = collections.find((collection) => collection.slug === button.dataset.shopCollection);
        renderCollection(nextCollection, 'theme');
      });
    });

    creatorButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextCreator = creators.find((creator) => creator.slug === button.dataset.shopCreator);
        renderCollection(nextCreator, 'creator');
      });
    });

    if (window.ShopifyBuy) {
      window.ShopifyBuy.UI ? ShopifyBuyInit() : loadScript();
    } else {
      loadScript();
    }
  })();
</script>
