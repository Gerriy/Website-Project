---
import BaseLayout from '../layouts/BaseLayout.astro';
import AssetSlot from '../components/AssetSlot.astro';
import MemberGrid from '../components/MemberGrid.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { siteCopy } from '../data/siteCopy';

const aboutCopy =
  siteCopy.about.traditionalChinese === '[TC copy pending]'
    ? siteCopy.homeAbout.traditionalChinese
    : siteCopy.about.traditionalChinese;
---

<BaseLayout title={siteCopy.metadata.aboutTitle} description={siteCopy.metadata.aboutDescription} page="about" paperMain>
  <section class="page-hero page-hero-compact shell" aria-labelledby="about-page-title">
    <h1 id="about-page-title" class="reveal">MASTA DAN</h1>
  </section>

  <section class="section shell story-section story-section-simple" aria-labelledby="story-heading">
    <AssetSlot
      src="assets/images/home/team-photo.png"
      alt="The Masta Dan team"
      label="Full team photograph"
      hint="public/assets/images/home/team-photo.png · 4:3"
      class="story-photo reveal"
    />
    <div class="prose reveal story-copy-card" style="--delay: 100ms">
      <h2 id="story-heading" class="sr-only">MASTA DAN introduction</h2>
      <p class="tc-placeholder">{aboutCopy}</p>
    </div>
  </section>

  <section class="section shell" id="members" aria-labelledby="all-members-heading">
    <div class="reveal"><SectionHeading heading="MEMBERS" id="all-members-heading" /></div>
    <MemberGrid />
  </section>
</BaseLayout>
