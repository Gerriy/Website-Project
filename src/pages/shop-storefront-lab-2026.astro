---
import BaseLayout from '../layouts/BaseLayout.astro';
import StorefrontShop from '../components/storefront/StorefrontShop';
import { creatorFilters } from '../data/shopCreators';
import { themeCollections } from '../data/shopCollections';
import { withBase } from '../utils/paths';

const storefrontConfig = {
  domain: import.meta.env.PUBLIC_SHOPIFY_DOMAIN || 'q1h1fd-1k.myshopify.com',
  token: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN || '',
  apiVersion: import.meta.env.PUBLIC_SHOPIFY_API_VERSION || '2026-04',
};
---

<BaseLayout
  title="Storefront API Lab · Masta Dan"
  description="Hidden Storefront API shopping test page for Masta Dan."
  page="shop"
  paperMain
  robots="noindex,nofollow"
>
  <section class="page-hero page-hero-compact shell" aria-labelledby="shop-lab-title">
    <h1 id="shop-lab-title">SHOPPING</h1>
  </section>

  <StorefrontShop
    client:load
    themeCollections={themeCollections}
    creatorFilters={creatorFilters}
    config={storefrontConfig}
    downIconSrc={withBase('assets/images/ui/down-button.png')}
  />

  <a class="back-to-top" href="#top" aria-label="Back to top"></a>
</BaseLayout>
