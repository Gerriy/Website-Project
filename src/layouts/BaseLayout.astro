---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/paths';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  page: 'home' | 'about' | 'shop';
  paperMain?: boolean;
  robots?: string;
}

const { title, description, page, paperMain = false, robots } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="theme-color" content="#ffffff" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={withBase('assets/images/brand/logo.png')} />
    <link rel="apple-touch-icon" href={withBase('assets/images/brand/logo.png')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@500;700;800;900&family=Rubik:wght@500;700;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header currentPage={page} />
    <main id="main" class:list={{ 'paper-field': paperMain, 'about-page': page === 'about', 'shop-page': page === 'shop' }}>
      <slot />
    </main>
    <Footer />
    {page !== 'shop' && (
      <a class="floating-shop-button" href={withBase('shop/')} aria-label="Go to shopping page">
        <img src={withBase('assets/images/ui/floating-button.png')} alt="" aria-hidden="true" />
      </a>
    )}
    <script>
      import '../scripts/site.js';
    </script>
  </body>
</html>
